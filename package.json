{
  "name": "linoem-hotel-control",
  "version": "1.0.0",
  "description": "Plataforma Hotelera Ultra-Premium (Backend + Frontend Monolith)",
  "main": "src/backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/backend/server.js",
    "dev:backend": "node --watch src/backend/server.js",
    "dev:frontend": "cd src/frontend && npm run dev",
    "build": "cd src/frontend && npm install && npm run build",
    "postbuild": "echo 'Build done'",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "check-syntax": "node --check src/backend/server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  },
  "author": "Jesus Emanuel Rivera Ruiz",
  "license": "ISC"
}
