generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}
enum Role {
  GUEST
  RECEPTION
  MANAGER
  ADMIN
}
enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}
enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}
model User {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  passwordHash    String?
  googleId        String?     @unique
  emailVerifiedAt DateTime?
  role            Role        @default(GUEST)
  active          Boolean     @default(true)
  sessions        Session[]
  tokens          AuthToken[]
  bookings        Booking[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([userId, expiresAt])
}
model AuthToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  purpose   String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId, purpose, expiresAt])
}
model Room {
  id          String      @id @default(cuid())
  number      String      @unique
  name        String
  type        String
  description String?
  price       Decimal     @db.Decimal(12, 2)
  capacity    Int         @default(2)
  status      RoomStatus  @default(AVAILABLE)
  imageUrl    String?
  bookings    Booking[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
model Booking {
  id        String        @id @default(cuid())
  folio     String        @unique
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  roomId    String
  room      Room          @relation(fields: [roomId], references: [id])
  checkIn   DateTime
  checkOut  DateTime
  guests    Int
  total     Decimal       @db.Decimal(12, 2)
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@index([roomId, checkIn, checkOut])
  @@index([userId, status])
}
